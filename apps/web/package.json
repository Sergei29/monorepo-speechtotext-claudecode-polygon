{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test:e2e:clean": "rm -rf test-results playwright-report blob-report",
    "test:e2e": "npm run test:e2e:clean && playwright test",
    "test:e2e:ui": "npm run test:e2e:clean && playwright test --ui --workers=1",
    "test:e2e:ci": "playwright test --reporter=list,html"
  },
  "dependencies": {
    "@repo/speechify-client": "workspace:*",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
